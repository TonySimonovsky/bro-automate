{
  "manifest_version": 3,
  "name": "Bro Automate",
  "version": "0.0.3",
  "description": "Turn any website into an API for AI agents, so they navigate the web faster and cheaper.",
  "icons": {
    "16": "icons/16.png",
    "32": "icons/32.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  },
  "permissions": ["debugger", "tabs", "tabGroups", "alarms", "offscreen"],
  "host_permissions": ["http://localhost/*"],
  "background": {
    "service_worker": "background.js"
  }
}
