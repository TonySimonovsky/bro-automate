{
  "schemaVersion": "1",
  "id": "fixture-evaluate-module",
  "name": "Fixture — module + evaluate (upwork-collect style)",
  "matches": [
    "https://www.upwork.com/ab/notifications/*",
    "https://www.upwork.com/jobs/*"
  ],
  "module": "scenario.js",
  "defaultParams": {
    "limit": 20
  },
  "steps": [
    { "type": "evaluate", "fn": "resolveJobUrls" },
    { "type": "evaluate", "fn": "scrapeAll", "args": { "source": "notifications" } }
  ]
}
